#!/bin/zsh
set -euo pipefail

label="com.hcassar93.codex-dictation-hooks"
install_path="$HOME/.local/bin/codex-dictation-hooks"
plist_path="$HOME/Library/LaunchAgents/$label.plist"
history_file="${CODEX_DICTATION_HISTORY:-$HOME/.codex/transcription-history.jsonl}"
stats_file="${CODEX_DICTATION_STATS:-$HOME/.config/codex-dictation-hooks/stats.json}"
log_dir="$HOME/.codex/log"
stdout_log="$log_dir/codex-dictation-hooks.out.log"
stderr_log="$log_dir/codex-dictation-hooks.err.log"
script_path="${0:A}"
script_dir="${script_path:h}"
hud_binary_path="$script_dir/codex-dictation-hooks-hud"
hud_source_path="$script_dir/codex-dictation-hooks-hud.swift"
hud_path="$hud_binary_path"
if [[ ! -f "$hud_path" && -f "$hud_source_path" ]]; then
  hud_path="$hud_source_path"
fi
repo_config_path="$script_dir/../config/hooks.json"
user_config_path="$HOME/.config/codex-dictation-hooks/hooks.json"
hooks_config="${CODEX_DICTATION_HOOKS_CONFIG:-}"

if [[ -z "$hooks_config" ]]; then
  if [[ -f "$repo_config_path" ]]; then
    hooks_config="$repo_config_path"
  else
    hooks_config="$user_config_path"
  fi
fi

find_node() {
  if [[ -n "${CODEX_DICTATION_NODE:-}" && -x "${CODEX_DICTATION_NODE:-}" ]]; then
    printf "%s" "$CODEX_DICTATION_NODE"
    return
  fi

  for candidate in \
    /opt/homebrew/bin/node \
    /usr/local/bin/node \
    /Applications/Codex.app/Contents/Resources/node; do
    if [[ -x "$candidate" ]]; then
      printf "%s" "$candidate"
      return
    fi
  done

  if command -v node >/dev/null 2>&1; then
    command -v node
    return
  fi

  printf "node"
}

watch_history() {
  mkdir -p "$(dirname "$history_file")"
  touch "$history_file"

  local node_bin
  node_bin="$(find_node)"

  CODEX_DICTATION_HOOKS_CONFIG="$hooks_config" CODEX_DICTATION_HUD_PATH="$hud_path" CODEX_DICTATION_STATS="$stats_file" "$node_bin" - "$history_file" <<'NODE'
const fs = require("fs");
const path = require("path");
const { spawn, spawnSync } = require("child_process");

const historyFile = process.argv[2];
const hooksConfigPath = process.env.CODEX_DICTATION_HOOKS_CONFIG;
const statsPath = process.env.CODEX_DICTATION_STATS;
let offset = fs.statSync(historyFile).size;
let buffer = "";
let hooksConfigCache = { mtimeMs: null, config: null };

function commandExists(command) {
  if (!command || typeof command !== "string") return false;

  const executable = command.trim().split(/\s+/)[0];
  if (!executable) return false;
  if (executable.includes("/")) return fs.existsSync(executable);

  const result = spawnSync("zsh", ["-lc", `command -v ${(JSON.stringify(executable))} >/dev/null 2>&1`]);
  return result.status === 0;
}

function readHooksConfig() {
  if (!hooksConfigPath || !fs.existsSync(hooksConfigPath)) return null;

  let stat;
  try {
    stat = fs.statSync(hooksConfigPath);
    if (hooksConfigCache.mtimeMs === stat.mtimeMs) return hooksConfigCache.config;

    const parsed = JSON.parse(fs.readFileSync(hooksConfigPath, "utf8"));
    hooksConfigCache = { mtimeMs: stat.mtimeMs, config: parsed };
    return parsed;
  } catch (error) {
    console.error(`Failed to read hooks config: ${error.message}`);
    if (!stat || hooksConfigCache.mtimeMs !== stat.mtimeMs) {
      showHudNotice({}, "Hooks config invalid");
    }
    hooksConfigCache = { mtimeMs: stat ? stat.mtimeMs : null, config: null };
    return null;
  }
}

function formatNumber(value) {
  return new Intl.NumberFormat().format(value);
}

function countWords(text) {
  const matches = String(text).match(/[\p{L}\p{N}]+(?:[’'][\p{L}\p{N}]+)*/gu);
  return matches ? matches.length : 0;
}

function defaultStats() {
  return {
    baseWords: 0,
    transcribedWords: 0,
    totalWords: 0,
    entries: 0,
    updatedAt: null,
  };
}

function normalizeCount(value) {
  const count = Number(value);
  return Number.isFinite(count) && count > 0 ? Math.floor(count) : 0;
}

function normalizeStats(stats) {
  const normalized = defaultStats();
  if (stats && typeof stats === "object") {
    normalized.baseWords = normalizeCount(stats.baseWords);
    normalized.transcribedWords = normalizeCount(stats.transcribedWords);
    normalized.entries = normalizeCount(stats.entries);
    normalized.updatedAt = typeof stats.updatedAt === "string" ? stats.updatedAt : null;
  }
  normalized.totalWords = normalized.baseWords + normalized.transcribedWords;
  return normalized;
}

function readStats() {
  if (!statsPath || !fs.existsSync(statsPath)) return defaultStats();

  try {
    return normalizeStats(JSON.parse(fs.readFileSync(statsPath, "utf8")));
  } catch (error) {
    console.error(`Failed to read tally: ${error.message}`);
    showHudNotice({}, "Tally file invalid");
    return defaultStats();
  }
}

function writeStats(stats) {
  if (!statsPath) return;

  fs.mkdirSync(path.dirname(statsPath), { recursive: true });
  const tmpPath = `${statsPath}.${process.pid}.tmp`;
  fs.writeFileSync(tmpPath, `${JSON.stringify(stats, null, 2)}\n`);
  fs.renameSync(tmpPath, statsPath);
}

function addToTally(text) {
  const wordCount = countWords(text);
  if (!wordCount) return null;

  const stats = readStats();
  stats.transcribedWords += wordCount;
  stats.entries += 1;
  stats.totalWords = stats.baseWords + stats.transcribedWords;
  stats.updatedAt = new Date().toISOString();
  writeStats(stats);

  return { wordCount, totalWords: stats.totalWords };
}

function findMatchingHook(text, hooks) {
  const normalized = text.toLocaleLowerCase();

  return hooks.find((hook) => {
    if (!hook || !Array.isArray(hook.phrases)) return false;

    return hook.phrases.some((phrase) => (
      typeof phrase === "string" &&
      phrase.trim().length > 0 &&
      normalized.includes(phrase.trim().toLocaleLowerCase())
    ));
  });
}

function renderPrompt(template, text) {
  return String(template || "{{text}}")
    .replaceAll("{{text}}", text)
    .replaceAll("{{model}}", "");
}

function shellQuote(value) {
  return `'${String(value).replaceAll("'", "'\\''")}'`;
}

function selectedModel(config, hook) {
  if (typeof hook.model === "string" && hook.model.trim()) return hook.model.trim();
  if (typeof config.defaultModel === "string" && config.defaultModel.trim()) return config.defaultModel.trim();

  return "";
}

function renderAgentCommand(command, model, config) {
  let rendered = String(command || "");

  if (model) {
    rendered = rendered.replaceAll("{{model}}", shellQuote(model));

    if (!String(command || "").includes("{{model}}") && typeof config.modelArgument === "string" && config.modelArgument.trim()) {
      rendered = `${rendered} ${config.modelArgument.replaceAll("{{model}}", shellQuote(model))}`;
    }
  } else {
    rendered = rendered.replaceAll("{{model}}", "");
  }

  return rendered;
}

function renderHookPrompt(template, text, model) {
  return String(template || "{{text}}")
    .replaceAll("{{text}}", text)
    .replaceAll("{{model}}", model || "");
}

function shouldShowHud(config = {}) {
  const envValue = process.env.CODEX_DICTATION_HUD;
  if (envValue === "0" || envValue === "false" || envValue === "off") return false;
  if (envValue === "1" || envValue === "true" || envValue === "on") return true;

  return config.showHud !== false;
}

function startHud(config = {}, args = []) {
  const hudPath = process.env.CODEX_DICTATION_HUD_PATH;
  if (!shouldShowHud(config) || !hudPath || !fs.existsSync(hudPath)) return null;

  try {
    const child = fs.statSync(hudPath).mode & 0o111
      ? spawn(hudPath, args, { detached: false, stdio: "ignore" })
      : commandExists("swift")
        ? spawn("/usr/bin/swift", [hudPath, ...args], { detached: false, stdio: "ignore" })
        : null;

    if (!child) return null;
    child.unref();
    return child;
  } catch {
    return null;
  }
}

function showHudMessage(config, kind, message) {
  const child = startHud(config, [kind, message]);
  if (child) child.unref();
}

function showHudNotice(config, message) {
  showHudMessage(config, "error", message);
}

function showHudInfo(config, message) {
  showHudMessage(config, "info", message);
}

function stopHud(child) {
  if (!child || child.killed) return;

  try {
    child.kill("SIGTERM");
  } catch {}
}

function maybeTransformText(text) {
  const config = readHooksConfig();
  if (!config || !Array.isArray(config.hooks)) return text;

  const hook = findMatchingHook(text, config.hooks);
  if (!hook) return text;

  const model = selectedModel(config, hook);
  const agentCommand = renderAgentCommand(process.env.CODEX_DICTATION_AGENT_COMMAND || config.agentCommand, model, config);
  if (!commandExists(agentCommand)) {
    console.error(`Matched hook "${hook.name || "unnamed"}" but agent command is unavailable.`);
    showHudNotice(config, "Hook agent unavailable");
    return text;
  }

  const prompt = renderHookPrompt(hook.prompt, text, model);
  const env = { ...process.env };
  if (model) env.CODEX_DICTATION_MODEL = model;
  if (hook.name) env.CODEX_DICTATION_HOOK_NAME = String(hook.name);

  const hud = startHud(config);
  const result = spawnSync("zsh", ["-lc", agentCommand], { input: prompt, encoding: "utf8", env });
  stopHud(hud);

  if (result.error || result.status !== 0) {
    const detail = result.error?.message || result.stderr?.trim() || `exit ${result.status}`;
    console.error(`Hook "${hook.name || "unnamed"}" failed: ${detail}`);
    showHudNotice(config, "Hook failed. Using original text.");
    return text;
  }

  const transformed = result.stdout.trim();
  if (!transformed) {
    showHudNotice(config, "Hook returned no text");
    return text;
  }

  const modelLabel = model ? ` using ${model}` : "";
  console.log(`[${new Date().toISOString()}] transformed dictation with hook: ${hook.name || "unnamed"}${modelLabel}`);
  return transformed;
}

function runAction(text) {
  const action = process.env.CODEX_DICTATION_ACTION;
  const result = action
    ? spawnSync("zsh", ["-lc", action], { input: text, encoding: "utf8" })
    : spawnSync("/usr/bin/pbcopy", { input: text, encoding: "utf8" });

  if (result.error) throw result.error;
  if (result.status !== 0) {
    throw new Error(`action exited with status ${result.status}`);
  }
}

function processLine(line) {
  if (!line.trim()) return;

  let item;
  try {
    item = JSON.parse(line);
  } catch {
    // Codex appends valid JSONL. Ignore partial or malformed lines.
    return;
  }

  const text = typeof item.text === "string" ? item.text.trim() : "";
  if (!text) return;

  try {
    const handledText = maybeTransformText(text);
    runAction(handledText);
    const tally = addToTally(text);
    if (tally) showHudInfo(readHooksConfig() || {}, `${formatNumber(tally.totalWords)} words total`);
    console.log(`[${new Date().toISOString()}] handled dictation: ${handledText}`);
  } catch (error) {
    console.error(`Failed to handle dictation: ${error.message}`);
    showHudNotice(readHooksConfig() || {}, "Could not handle dictation");
  }
}

function poll() {
  let size;

  try {
    size = fs.statSync(historyFile).size;
  } catch {
    return;
  }

  if (size < offset) {
    offset = 0;
    buffer = "";
  }

  if (size <= offset) return;

  const fd = fs.openSync(historyFile, "r");
  try {
    const chunk = Buffer.alloc(size - offset);
    fs.readSync(fd, chunk, 0, chunk.length, offset);
    offset = size;
    buffer += chunk.toString("utf8");
  } finally {
    fs.closeSync(fd);
  }

  let newlineIndex;
  while ((newlineIndex = buffer.indexOf("\n")) !== -1) {
    const line = buffer.slice(0, newlineIndex);
    buffer = buffer.slice(newlineIndex + 1);
    processLine(line);
  }
}

setInterval(poll, 500);
console.log(`Watching ${historyFile}`);
NODE
}

handle_latest() {
  local node_bin
  local text
  node_bin="$(find_node)"

  text="$(CODEX_DICTATION_HOOKS_CONFIG="$hooks_config" CODEX_DICTATION_HUD_PATH="$hud_path" "$node_bin" - "$history_file" <<'NODE'
const fs = require("fs");
const { spawn, spawnSync } = require("child_process");

const historyFile = process.argv[2];
const hooksConfigPath = process.env.CODEX_DICTATION_HOOKS_CONFIG;

function commandExists(command) {
  if (!command || typeof command !== "string") return false;

  const executable = command.trim().split(/\s+/)[0];
  if (!executable) return false;
  if (executable.includes("/")) return fs.existsSync(executable);

  const result = spawnSync("zsh", ["-lc", `command -v ${JSON.stringify(executable)} >/dev/null 2>&1`]);
  return result.status === 0;
}

function readHooksConfig() {
  if (!hooksConfigPath || !fs.existsSync(hooksConfigPath)) return null;

  try {
    return JSON.parse(fs.readFileSync(hooksConfigPath, "utf8"));
  } catch (error) {
    console.error(`Failed to read hooks config: ${error.message}`);
    showHudNotice({}, "Hooks config invalid");
    return null;
  }
}

function findMatchingHook(text, hooks) {
  const normalized = text.toLocaleLowerCase();

  return hooks.find((hook) => {
    if (!hook || !Array.isArray(hook.phrases)) return false;

    return hook.phrases.some((phrase) => (
      typeof phrase === "string" &&
      phrase.trim().length > 0 &&
      normalized.includes(phrase.trim().toLocaleLowerCase())
    ));
  });
}

function renderPrompt(template, text) {
  return String(template || "{{text}}")
    .replaceAll("{{text}}", text)
    .replaceAll("{{model}}", "");
}

function shellQuote(value) {
  return `'${String(value).replaceAll("'", "'\\''")}'`;
}

function selectedModel(config, hook) {
  if (typeof hook.model === "string" && hook.model.trim()) return hook.model.trim();
  if (typeof config.defaultModel === "string" && config.defaultModel.trim()) return config.defaultModel.trim();

  return "";
}

function renderAgentCommand(command, model, config) {
  let rendered = String(command || "");

  if (model) {
    rendered = rendered.replaceAll("{{model}}", shellQuote(model));

    if (!String(command || "").includes("{{model}}") && typeof config.modelArgument === "string" && config.modelArgument.trim()) {
      rendered = `${rendered} ${config.modelArgument.replaceAll("{{model}}", shellQuote(model))}`;
    }
  } else {
    rendered = rendered.replaceAll("{{model}}", "");
  }

  return rendered;
}

function renderHookPrompt(template, text, model) {
  return String(template || "{{text}}")
    .replaceAll("{{text}}", text)
    .replaceAll("{{model}}", model || "");
}

function shouldShowHud(config = {}) {
  const envValue = process.env.CODEX_DICTATION_HUD;
  if (envValue === "0" || envValue === "false" || envValue === "off") return false;
  if (envValue === "1" || envValue === "true" || envValue === "on") return true;

  return config.showHud !== false;
}

function startHud(config = {}, args = []) {
  const hudPath = process.env.CODEX_DICTATION_HUD_PATH;
  if (!shouldShowHud(config) || !hudPath || !fs.existsSync(hudPath)) return null;

  try {
    const child = fs.statSync(hudPath).mode & 0o111
      ? spawn(hudPath, args, { detached: false, stdio: "ignore" })
      : commandExists("swift")
        ? spawn("/usr/bin/swift", [hudPath, ...args], { detached: false, stdio: "ignore" })
        : null;

    if (!child) return null;
    child.unref();
    return child;
  } catch {
    return null;
  }
}

function showHudNotice(config, message) {
  const child = startHud(config, ["error", message]);
  if (child) child.unref();
}

function stopHud(child) {
  if (!child || child.killed) return;

  try {
    child.kill("SIGTERM");
  } catch {}
}

function maybeTransformText(text) {
  const config = readHooksConfig();
  if (!config || !Array.isArray(config.hooks)) return text;

  const hook = findMatchingHook(text, config.hooks);
  if (!hook) return text;

  const model = selectedModel(config, hook);
  const agentCommand = renderAgentCommand(process.env.CODEX_DICTATION_AGENT_COMMAND || config.agentCommand, model, config);
  if (!commandExists(agentCommand)) {
    showHudNotice(config, "Hook agent unavailable");
    return text;
  }

  const prompt = renderHookPrompt(hook.prompt, text, model);
  const env = { ...process.env };
  if (model) env.CODEX_DICTATION_MODEL = model;
  if (hook.name) env.CODEX_DICTATION_HOOK_NAME = String(hook.name);

  const hud = startHud(config);
  const result = spawnSync("zsh", ["-lc", agentCommand], { input: prompt, encoding: "utf8", env });
  stopHud(hud);

  if (result.error || result.status !== 0) {
    showHudNotice(config, "Hook failed. Using original text.");
    return text;
  }

  const transformed = result.stdout.trim();
  if (!transformed) showHudNotice(config, "Hook returned no text");

  return transformed || text;
}

const lines = fs.existsSync(historyFile)
  ? fs.readFileSync(historyFile, "utf8").trim().split(/\r?\n/).reverse()
  : [];

for (const line of lines) {
  try {
    const item = JSON.parse(line);
    if (typeof item.text === "string" && item.text.trim()) {
      process.stdout.write(maybeTransformText(item.text.trim()));
      process.exit(0);
    }
  } catch {}
}
NODE
)"

  [[ -z "$text" ]] && return

  if [[ -n "${CODEX_DICTATION_ACTION:-}" ]]; then
    printf "%s" "$text" | zsh -lc "$CODEX_DICTATION_ACTION"
  else
    printf "%s" "$text" | /usr/bin/pbcopy
  fi
}

tally_command() {
  local command="${1:-view}"
  local value="${2:-}"
  local node_bin
  node_bin="$(find_node)"

  "$node_bin" - "$stats_file" "$command" "$value" <<'NODE'
const fs = require("fs");
const path = require("path");

const statsPath = process.argv[2];
const command = process.argv[3] || "view";
const value = process.argv[4] || "";

function defaultStats() {
  return {
    baseWords: 0,
    transcribedWords: 0,
    totalWords: 0,
    entries: 0,
    updatedAt: null,
  };
}

function normalizeCount(raw) {
  if (raw === null || raw === undefined || String(raw).trim() === "") return null;
  const count = Number(raw);
  return Number.isFinite(count) && count >= 0 ? Math.floor(count) : null;
}

function normalizeStats(stats) {
  const normalized = defaultStats();
  if (stats && typeof stats === "object") {
    normalized.baseWords = normalizeCount(stats.baseWords) ?? 0;
    normalized.transcribedWords = normalizeCount(stats.transcribedWords) ?? 0;
    normalized.entries = normalizeCount(stats.entries) ?? 0;
    normalized.updatedAt = typeof stats.updatedAt === "string" ? stats.updatedAt : null;
  }
  normalized.totalWords = normalized.baseWords + normalized.transcribedWords;
  return normalized;
}

function readStats() {
  if (!fs.existsSync(statsPath)) return defaultStats();
  return normalizeStats(JSON.parse(fs.readFileSync(statsPath, "utf8")));
}

function writeStats(stats) {
  fs.mkdirSync(path.dirname(statsPath), { recursive: true });
  const tmpPath = `${statsPath}.${process.pid}.tmp`;
  fs.writeFileSync(tmpPath, `${JSON.stringify(stats, null, 2)}\n`);
  fs.renameSync(tmpPath, statsPath);
}

function formatNumber(count) {
  return new Intl.NumberFormat().format(count);
}

function printStats(stats) {
  console.log(`Total words: ${formatNumber(stats.totalWords)}`);
  console.log(`Base words: ${formatNumber(stats.baseWords)}`);
  console.log(`Tracked words: ${formatNumber(stats.transcribedWords)}`);
  console.log(`Entries: ${formatNumber(stats.entries)}`);
  if (stats.updatedAt) console.log(`Updated: ${stats.updatedAt}`);
  console.log(`File: ${statsPath}`);
}

if (command === "view") {
  printStats(readStats());
} else if (command === "import") {
  const baseWords = normalizeCount(value);
  if (baseWords === null) {
    console.error("Usage: codex-dictation-hooks import-tally <non-negative-word-count>");
    process.exit(2);
  }

  const stats = readStats();
  stats.baseWords = baseWords;
  stats.totalWords = stats.baseWords + stats.transcribedWords;
  stats.updatedAt = new Date().toISOString();
  writeStats(stats);
  printStats(stats);
} else {
  console.error("Usage: codex-dictation-hooks tally | import-tally <word-count>");
  process.exit(2);
}
NODE
}

install_agent() {
  mkdir -p "$(dirname "$install_path")" "$HOME/Library/LaunchAgents" "$log_dir"
  cp "$script_path" "$install_path"
  chmod +x "$install_path"
  if [[ -f "$hud_path" ]]; then
    local hud_install_path
    hud_install_path="$(dirname "$install_path")/codex-dictation-hooks-hud"
    if [[ -f "$hud_source_path" ]] && command -v swiftc >/dev/null 2>&1; then
      swiftc "$hud_source_path" -o "$hud_install_path"
    elif [[ -x "$hud_binary_path" ]]; then
      cp "$hud_binary_path" "$hud_install_path"
      chmod +x "$hud_install_path"
    else
      cp "$hud_source_path" "$hud_install_path.swift"
    fi
  fi

  /usr/bin/env python3 - "$plist_path" "$label" "$install_path" "$stdout_log" "$stderr_log" "$PATH" <<'PY'
import plistlib
import sys

plist_path, label, install_path, stdout_log, stderr_log, path = sys.argv[1:]
plist = {
    "Label": label,
    "ProgramArguments": [install_path, "watch"],
    "RunAtLoad": True,
    "KeepAlive": True,
    "EnvironmentVariables": {
        "PATH": path,
    },
    "StandardOutPath": stdout_log,
    "StandardErrorPath": stderr_log,
}

with open(plist_path, "wb") as f:
    plistlib.dump(plist, f)
PY

  launchctl bootout "gui/$(id -u)" "$plist_path" >/dev/null 2>&1 || true
  launchctl bootstrap "gui/$(id -u)" "$plist_path"
  launchctl enable "gui/$(id -u)/$label" >/dev/null 2>&1 || true
  launchctl kickstart -k "gui/$(id -u)/$label"

  printf "Installed %s\n" "$label"
}

uninstall_agent() {
  launchctl bootout "gui/$(id -u)" "$plist_path" >/dev/null 2>&1 || true
  rm -f "$plist_path"
  printf "Uninstalled %s\n" "$label"
}

status_agent() {
  launchctl print "gui/$(id -u)/$label"
}

case "${1:-watch}" in
  watch)
    watch_history
    ;;
  install)
    install_agent
    ;;
  uninstall)
    uninstall_agent
    ;;
  status)
    status_agent
    ;;
  latest)
    handle_latest
    ;;
  tally)
    tally_command view
    ;;
  import-tally)
    tally_command import "${2:-}"
    ;;
  *)
    printf "Usage: %s [watch|install|uninstall|status|latest|tally|import-tally <word-count>]\n" "$0" >&2
    exit 2
    ;;
esac
