#!/bin/zsh
set -euo pipefail

script_path="${0:A}"
script_dir="${script_path:h}"
node_script="$script_dir/codex-dictation-hooks.js"

find_node() {
  if [[ -n "${CODEX_DICTATION_NODE:-}" && -x "${CODEX_DICTATION_NODE:-}" ]]; then
    printf "%s" "$CODEX_DICTATION_NODE"
    return
  fi

  for candidate in \
    /opt/homebrew/bin/node \
    /usr/local/bin/node \
    /Applications/Codex.app/Contents/Resources/node; do
    if [[ -x "$candidate" ]]; then
      printf "%s" "$candidate"
      return
    fi
  done

  if command -v node >/dev/null 2>&1; then
    command -v node
    return
  fi

  printf "node"
}

exec "$(find_node)" "$node_script" "$@"
