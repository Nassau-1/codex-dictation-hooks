#!/bin/zsh
set -euo pipefail

label="com.hcassar93.codex-dictation-hooks"
install_path="$HOME/.local/bin/codex-dictation-hooks"
plist_path="$HOME/Library/LaunchAgents/$label.plist"
history_file="${CODEX_DICTATION_HISTORY:-$HOME/.codex/transcription-history.jsonl}"
log_dir="$HOME/.codex/log"
stdout_log="$log_dir/codex-dictation-hooks.out.log"
stderr_log="$log_dir/codex-dictation-hooks.err.log"
script_path="${0:A}"
script_dir="${script_path:h}"
repo_config_path="$script_dir/../config/hooks.json"
user_config_path="$HOME/.config/codex-dictation-hooks/hooks.json"
hooks_config="${CODEX_DICTATION_HOOKS_CONFIG:-}"

if [[ -z "$hooks_config" ]]; then
  if [[ -f "$repo_config_path" ]]; then
    hooks_config="$repo_config_path"
  else
    hooks_config="$user_config_path"
  fi
fi

find_node() {
  if [[ -n "${CODEX_DICTATION_NODE:-}" && -x "${CODEX_DICTATION_NODE:-}" ]]; then
    printf "%s" "$CODEX_DICTATION_NODE"
    return
  fi

  for candidate in \
    /opt/homebrew/bin/node \
    /usr/local/bin/node \
    /Applications/Codex.app/Contents/Resources/node; do
    if [[ -x "$candidate" ]]; then
      printf "%s" "$candidate"
      return
    fi
  done

  if command -v node >/dev/null 2>&1; then
    command -v node
    return
  fi

  printf "node"
}

watch_history() {
  mkdir -p "$(dirname "$history_file")"
  touch "$history_file"

  local node_bin
  node_bin="$(find_node)"

  CODEX_DICTATION_HOOKS_CONFIG="$hooks_config" "$node_bin" - "$history_file" <<'NODE'
const fs = require("fs");
const { spawnSync } = require("child_process");

const historyFile = process.argv[2];
const hooksConfigPath = process.env.CODEX_DICTATION_HOOKS_CONFIG;
let offset = fs.statSync(historyFile).size;
let buffer = "";
let hooksConfigCache = { mtimeMs: null, config: null };

function commandExists(command) {
  if (!command || typeof command !== "string") return false;

  const executable = command.trim().split(/\s+/)[0];
  if (!executable) return false;
  if (executable.includes("/")) return fs.existsSync(executable);

  const result = spawnSync("zsh", ["-lc", `command -v ${(JSON.stringify(executable))} >/dev/null 2>&1`]);
  return result.status === 0;
}

function readHooksConfig() {
  if (!hooksConfigPath || !fs.existsSync(hooksConfigPath)) return null;

  try {
    const stat = fs.statSync(hooksConfigPath);
    if (hooksConfigCache.mtimeMs === stat.mtimeMs) return hooksConfigCache.config;

    const parsed = JSON.parse(fs.readFileSync(hooksConfigPath, "utf8"));
    hooksConfigCache = { mtimeMs: stat.mtimeMs, config: parsed };
    return parsed;
  } catch (error) {
    console.error(`Failed to read hooks config: ${error.message}`);
    hooksConfigCache = { mtimeMs: null, config: null };
    return null;
  }
}

function findMatchingHook(text, hooks) {
  const normalized = text.toLocaleLowerCase();

  return hooks.find((hook) => {
    if (!hook || !Array.isArray(hook.phrases)) return false;

    return hook.phrases.some((phrase) => (
      typeof phrase === "string" &&
      phrase.trim().length > 0 &&
      normalized.includes(phrase.trim().toLocaleLowerCase())
    ));
  });
}

function renderPrompt(template, text) {
  return String(template || "{{text}}")
    .replaceAll("{{text}}", text)
    .replaceAll("{{model}}", "");
}

function shellQuote(value) {
  return `'${String(value).replaceAll("'", "'\\''")}'`;
}

function selectedModel(config, hook) {
  if (typeof hook.model === "string" && hook.model.trim()) return hook.model.trim();
  if (typeof config.defaultModel === "string" && config.defaultModel.trim()) return config.defaultModel.trim();

  return "";
}

function renderAgentCommand(command, model, config) {
  let rendered = String(command || "");

  if (model) {
    rendered = rendered.replaceAll("{{model}}", shellQuote(model));

    if (!String(command || "").includes("{{model}}") && typeof config.modelArgument === "string" && config.modelArgument.trim()) {
      rendered = `${rendered} ${config.modelArgument.replaceAll("{{model}}", shellQuote(model))}`;
    }
  } else {
    rendered = rendered.replaceAll("{{model}}", "");
  }

  return rendered;
}

function renderHookPrompt(template, text, model) {
  return String(template || "{{text}}")
    .replaceAll("{{text}}", text)
    .replaceAll("{{model}}", model || "");
}

function maybeTransformText(text) {
  const config = readHooksConfig();
  if (!config || !Array.isArray(config.hooks)) return text;

  const hook = findMatchingHook(text, config.hooks);
  if (!hook) return text;

  const model = selectedModel(config, hook);
  const agentCommand = renderAgentCommand(process.env.CODEX_DICTATION_AGENT_COMMAND || config.agentCommand, model, config);
  if (!commandExists(agentCommand)) {
    console.error(`Matched hook "${hook.name || "unnamed"}" but agent command is unavailable.`);
    return text;
  }

  const prompt = renderHookPrompt(hook.prompt, text, model);
  const env = { ...process.env };
  if (model) env.CODEX_DICTATION_MODEL = model;
  if (hook.name) env.CODEX_DICTATION_HOOK_NAME = String(hook.name);

  const result = spawnSync(agentCommand, { input: prompt, encoding: "utf8", shell: true, env });

  if (result.error || result.status !== 0) {
    const detail = result.error?.message || result.stderr?.trim() || `exit ${result.status}`;
    console.error(`Hook "${hook.name || "unnamed"}" failed: ${detail}`);
    return text;
  }

  const transformed = result.stdout.trim();
  if (!transformed) return text;

  const modelLabel = model ? ` using ${model}` : "";
  console.log(`[${new Date().toISOString()}] transformed dictation with hook: ${hook.name || "unnamed"}${modelLabel}`);
  return transformed;
}

function runAction(text) {
  const action = process.env.CODEX_DICTATION_ACTION;
  const result = action
    ? spawnSync(action, { input: text, encoding: "utf8", shell: true })
    : spawnSync("/usr/bin/pbcopy", { input: text, encoding: "utf8" });

  if (result.error) throw result.error;
  if (result.status !== 0) {
    throw new Error(`action exited with status ${result.status}`);
  }
}

function processLine(line) {
  if (!line.trim()) return;

  try {
    const item = JSON.parse(line);
    const text = typeof item.text === "string" ? item.text.trim() : "";
    if (!text) return;

    const handledText = maybeTransformText(text);
    runAction(handledText);
    console.log(`[${new Date().toISOString()}] handled dictation: ${handledText}`);
  } catch {
    // Codex appends valid JSONL. Ignore partial or malformed lines.
  }
}

function poll() {
  let size;

  try {
    size = fs.statSync(historyFile).size;
  } catch {
    return;
  }

  if (size < offset) {
    offset = 0;
    buffer = "";
  }

  if (size <= offset) return;

  const fd = fs.openSync(historyFile, "r");
  try {
    const chunk = Buffer.alloc(size - offset);
    fs.readSync(fd, chunk, 0, chunk.length, offset);
    offset = size;
    buffer += chunk.toString("utf8");
  } finally {
    fs.closeSync(fd);
  }

  let newlineIndex;
  while ((newlineIndex = buffer.indexOf("\n")) !== -1) {
    const line = buffer.slice(0, newlineIndex);
    buffer = buffer.slice(newlineIndex + 1);
    processLine(line);
  }
}

setInterval(poll, 500);
console.log(`Watching ${historyFile}`);
NODE
}

handle_latest() {
  local node_bin
  local text
  node_bin="$(find_node)"

  text="$(CODEX_DICTATION_HOOKS_CONFIG="$hooks_config" "$node_bin" - "$history_file" <<'NODE'
const fs = require("fs");
const { spawnSync } = require("child_process");

const historyFile = process.argv[2];
const hooksConfigPath = process.env.CODEX_DICTATION_HOOKS_CONFIG;

function commandExists(command) {
  if (!command || typeof command !== "string") return false;

  const executable = command.trim().split(/\s+/)[0];
  if (!executable) return false;
  if (executable.includes("/")) return fs.existsSync(executable);

  const result = spawnSync("zsh", ["-lc", `command -v ${JSON.stringify(executable)} >/dev/null 2>&1`]);
  return result.status === 0;
}

function readHooksConfig() {
  if (!hooksConfigPath || !fs.existsSync(hooksConfigPath)) return null;

  try {
    return JSON.parse(fs.readFileSync(hooksConfigPath, "utf8"));
  } catch {
    return null;
  }
}

function findMatchingHook(text, hooks) {
  const normalized = text.toLocaleLowerCase();

  return hooks.find((hook) => {
    if (!hook || !Array.isArray(hook.phrases)) return false;

    return hook.phrases.some((phrase) => (
      typeof phrase === "string" &&
      phrase.trim().length > 0 &&
      normalized.includes(phrase.trim().toLocaleLowerCase())
    ));
  });
}

function renderPrompt(template, text) {
  return String(template || "{{text}}")
    .replaceAll("{{text}}", text)
    .replaceAll("{{model}}", "");
}

function shellQuote(value) {
  return `'${String(value).replaceAll("'", "'\\''")}'`;
}

function selectedModel(config, hook) {
  if (typeof hook.model === "string" && hook.model.trim()) return hook.model.trim();
  if (typeof config.defaultModel === "string" && config.defaultModel.trim()) return config.defaultModel.trim();

  return "";
}

function renderAgentCommand(command, model, config) {
  let rendered = String(command || "");

  if (model) {
    rendered = rendered.replaceAll("{{model}}", shellQuote(model));

    if (!String(command || "").includes("{{model}}") && typeof config.modelArgument === "string" && config.modelArgument.trim()) {
      rendered = `${rendered} ${config.modelArgument.replaceAll("{{model}}", shellQuote(model))}`;
    }
  } else {
    rendered = rendered.replaceAll("{{model}}", "");
  }

  return rendered;
}

function renderHookPrompt(template, text, model) {
  return String(template || "{{text}}")
    .replaceAll("{{text}}", text)
    .replaceAll("{{model}}", model || "");
}

function maybeTransformText(text) {
  const config = readHooksConfig();
  if (!config || !Array.isArray(config.hooks)) return text;

  const hook = findMatchingHook(text, config.hooks);
  if (!hook) return text;

  const model = selectedModel(config, hook);
  const agentCommand = renderAgentCommand(process.env.CODEX_DICTATION_AGENT_COMMAND || config.agentCommand, model, config);
  if (!commandExists(agentCommand)) return text;

  const prompt = renderHookPrompt(hook.prompt, text, model);
  const env = { ...process.env };
  if (model) env.CODEX_DICTATION_MODEL = model;
  if (hook.name) env.CODEX_DICTATION_HOOK_NAME = String(hook.name);

  const result = spawnSync(agentCommand, { input: prompt, encoding: "utf8", shell: true, env });
  const transformed = result.status === 0 ? result.stdout.trim() : "";

  return transformed || text;
}

const lines = fs.existsSync(historyFile)
  ? fs.readFileSync(historyFile, "utf8").trim().split(/\r?\n/).reverse()
  : [];

for (const line of lines) {
  try {
    const item = JSON.parse(line);
    if (typeof item.text === "string" && item.text.trim()) {
      process.stdout.write(maybeTransformText(item.text.trim()));
      process.exit(0);
    }
  } catch {}
}
NODE
)"

  [[ -z "$text" ]] && return

  if [[ -n "${CODEX_DICTATION_ACTION:-}" ]]; then
    printf "%s" "$text" | zsh -c "$CODEX_DICTATION_ACTION"
  else
    printf "%s" "$text" | /usr/bin/pbcopy
  fi
}

install_agent() {
  mkdir -p "$(dirname "$install_path")" "$HOME/Library/LaunchAgents" "$log_dir"
  cp "$script_path" "$install_path"
  chmod +x "$install_path"

  /usr/bin/env python3 - "$plist_path" "$label" "$install_path" "$stdout_log" "$stderr_log" <<'PY'
import plistlib
import sys

plist_path, label, install_path, stdout_log, stderr_log = sys.argv[1:]
plist = {
    "Label": label,
    "ProgramArguments": [install_path, "watch"],
    "RunAtLoad": True,
    "KeepAlive": True,
    "StandardOutPath": stdout_log,
    "StandardErrorPath": stderr_log,
}

with open(plist_path, "wb") as f:
    plistlib.dump(plist, f)
PY

  launchctl bootout "gui/$(id -u)" "$plist_path" >/dev/null 2>&1 || true
  launchctl bootstrap "gui/$(id -u)" "$plist_path"
  launchctl enable "gui/$(id -u)/$label" >/dev/null 2>&1 || true
  launchctl kickstart -k "gui/$(id -u)/$label"

  printf "Installed %s\n" "$label"
}

uninstall_agent() {
  launchctl bootout "gui/$(id -u)" "$plist_path" >/dev/null 2>&1 || true
  rm -f "$plist_path"
  printf "Uninstalled %s\n" "$label"
}

status_agent() {
  launchctl print "gui/$(id -u)/$label"
}

case "${1:-watch}" in
  watch)
    watch_history
    ;;
  install)
    install_agent
    ;;
  uninstall)
    uninstall_agent
    ;;
  status)
    status_agent
    ;;
  latest)
    handle_latest
    ;;
  *)
    printf "Usage: %s [watch|install|uninstall|status|latest]\n" "$0" >&2
    exit 2
    ;;
esac
